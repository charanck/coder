{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Unit Tests",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-q",
        "tests/unit"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug Current Unit Test File",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-q",
        "${file}"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}